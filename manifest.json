{
  "manifest_version": 3,
  "name": "d-OP",
  "version": "1.0.0",
  "description": "dアニメストアの動画からOP/EDのみを抽出して再生するブラウザ拡張機能",
  "homepage_url": "https://github.com/sas-news/d-op",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "windows"
  ],
  "host_permissions": [
    "https://animestore.docomo.ne.jp/*",
    "https://anime.dmkt-sp.jp/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["browser-polyfill.js", "background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "d-op@d-anime.store"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "d-OP"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://animestore.docomo.ne.jp/animestore/sc_d_pc?*",
        "https://anime.dmkt-sp.jp/animestore/sc_d_pc?*"
      ],
      "js": [
        "browser-polyfill.js",
        "common.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://animestore.docomo.ne.jp/animestore/*",
        "https://anime.dmkt-sp.jp/animestore/*"
      ],
      "exclude_matches": [
        "https://animestore.docomo.ne.jp/animestore/sc_d_pc?*",
        "https://anime.dmkt-sp.jp/animestore/sc_d_pc?*"
      ],
      "js": [
        "browser-polyfill.js",
        "common.js",
        "content-store.js"
      ],
      "css": [
        "styles-store.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "injected.js"
      ],
      "matches": [
        "https://animestore.docomo.ne.jp/*",
        "https://anime.dmkt-sp.jp/*"
      ]
    }
  ]
}
